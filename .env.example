# Copy to .env (never commit .env). Placeholders only - real values live in your
# local .env and, in production, AWS Secrets Manager / Vercel env vars.

# --- Database (local dev: docker compose up db) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wren
# Backend app role (created by migration 0002; used by the API instead of postgres).
# REQUIRED: min 8 chars, no quotes/backslashes/dollar signs; the migration runner
# fails closed on the placeholder below or unsafe characters.
WREN_APP_DB_PASSWORD=change-me

# --- Supabase (auth) - wired in T-004 ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# --- LLM provider (Azure OpenAI) - wired in T-008 ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# --- Reranker (T-009): 'cohere' or 'local' ---
RERANKER=local
COHERE_API_KEY=

# --- Observability (Langfuse) - wired in T-030 ---
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Frontend (frontend/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
