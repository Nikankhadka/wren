# Copy to .env (never commit .env). Placeholders only - real values live in your
# local .env and, in production, AWS Secrets Manager / Vercel env vars.

# --- Database (local dev: docker compose up db) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wren
# Backend app role (created by migration 0002; used by the API instead of postgres).
# REQUIRED: min 8 chars, no quotes/backslashes/dollar signs; the migration runner
# fails closed on the placeholder below or unsafe characters.
WREN_APP_DB_PASSWORD=change-me

# --- Supabase (auth) - wired in T-004 ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# --- Chat LLM provider: 'azure' or 'openai_compat' ---
# 'openai_compat' works with any OpenAI-compatible endpoint. Free examples:
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1  LLM_MODEL=google/gemini-2.0-flash-exp:free
#   Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.3-70b-versatile
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=llama3.2  (LLM_API_KEY ignored)
# The model must support structured outputs (json_schema) - onboarding and
# routing rely on it.
LLM_PROVIDER=azure
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# --- Azure OpenAI (when LLM_PROVIDER=azure and/or EMBEDDER=azure) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# --- Embedder: 'local' (default - free, keyless sentence-transformers) or 'azure' ---
# EMBEDDING_DIM must match knowledge_chunks.embedding's vector(N) (migration
# 0010). The default local model is natively 384; Azure truncates to 384
# server-side, so switching needs no migration - only re-ingesting documents.
EMBEDDER=local
LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Reranker (T-009): 'cohere' or 'local' ---
RERANKER=local
COHERE_API_KEY=

# --- Observability (Langfuse) - wired in T-030 ---
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Frontend (frontend/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
