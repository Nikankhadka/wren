{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && uv run uvicorn app.main:app --reload --port ${PORT:-8000}"],
      "port": 8000,
      "autoPort": true
    },
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev -- -p ${PORT:-3000}"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
